@startuml
title Hakim Color Lab Authentication & Usage Flow

start

:Open hakimcolorlab.xyz;

repeat

  partition "User Device" {
    :Enter Login Credentials;
    :Submit Form;
  }

  partition "Auth Service" {
    :Validate Credentials;
  }

  if (Credentials Valid?) then (Yes)

    partition "Auth Service" {
      :Set User Cookie for Session;
    }

    partition "User Device" {
      :Redirect to color.html;
    }

    partition "Active Session" {

      repeat

        partition "User Device" {
          :Choose Action;
        }

        if (Action Type?) then (Add Color)

          partition "User Device" {
            :Input New Color;
          }

          partition "Database" {
            :Insert Color Record;
          }

        else (Search)

          partition "User Device" {
            :Enter Search Query;
          }

          partition "Database" {
            :Retrieve Matching Colors;
          }

          partition "User Device" {
            :Display Results;
          }

        endif

      repeat while (User Logs Out?) is (No) not (Yes)

    }

    partition "User Device" {
      :Redirect to Home Page;
    }

  else (No)

    partition "User Device" {
      :Display "Invalid Login" Message;
    }

  endif

repeat while (Retry Login?) is (Yes) not (No)

stop

@enduml
